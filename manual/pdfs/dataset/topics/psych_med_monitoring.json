                "Basal",
                "Seguimiento"
            ],
            "rows": [
                [
                    "Función hepática",
                    "Sí",
                    "Periódico (3-6 meses)"
                ],
                [
                    "Biometría hemática",
                    "Sí",
                    "Periódico"
                ],
                [
                    "Prueba de embarazo (si aplica)",
                    "Sí",
                    "Según riesgo"
                ]
            ]
        },
        {
            "id": "psych_med_education",
            "type": "checklist",
            "title": "Plantilla fija de educación al paciente (60 segundos)",
            "audience": "clinician",
            "items": [
                "Qué es y por qué importa hoy (1–2 frases).",
                "Qué esperamos lograr (beneficio observable y horizonte temporal).",
                "Efectos esperables frecuentes (2) y qué hacer.",
                "Señales de alarma para urgencias (3).",
                "Autocuidado mínimo (1–2 acciones concretas)."
            ]
        },
