            "audience": "clinician",
            "content": "El diagnóstico requiere historia de episodios maníacos/hipomaníacos y depresión."
        },
        {
            "id": "psych_bipolar_mania",
            "type": "checklist",
            "title": "Características de manía/hipomanía",
            "audience": "clinician",
            "items": [
                "Estado de ánimo elevado/irritable con aumento de energía.",
                "Disminución de necesidad de sueño.",
                "Aumento de actividad, verborrea, fuga de ideas.",
                "Conductas de riesgo o juicio disminuido.",
                "Duración típica: manía ≥1 semana o cualquier duración con hospitalización; hipomanía ≥4 días."
            ]
        },
        {
            "id": "psych_bipolar_treatment",
            "type": "section",
            "title": "Tratamiento inicial",
            "audience": "clinician",
            "content": "Seleccione estabilizadores del estado de ánimo y antipsicóticos según fase clínica.",
            "sub_blocks": [
                {
                    "id": "psych_bipolar_general",
                    "type": "list",
                    "title": "Recomendaciones generales",
                    "audience": "clinician",
                    "items": [
                        "Manía aguda: estabilizador del ánimo y/o antipsicótico; considerar hospitalización si hay riesgo.",
                        "Depresión bipolar: evitar antidepresivos en monoterapia; usar opciones con evidencia.",
                        "Psicoeducación, regularidad de sueño y reducción de sustancias son claves."
                    ]
                },
                {
                    "id": "psych_bipolar_warning",
                    "type": "alert",
                    "title": "Advertencia",
                    "level": "warning",
                    "audience": "clinician",
                    "content": "Los antidepresivos en monoterapia pueden precipitar manía o ciclado rápido."
                }
            ]
        },
