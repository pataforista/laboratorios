{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/dataset.schema.json",
  "title": "Manual PWA Dataset Schema (v0.3 patched)",
  "type": "object",
  "required": [
    "schema_version",
    "dataset_id",
    "topics",
    "printables"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "dataset_id": {
      "type": "string"
    },
    "topics": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/topicRef"
      }
    },
    "printables": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/printableRef"
      }
    }
  },
  "definitions": {
    "topicRef": {
      "type": "object",
      "required": [
        "id",
        "title",
        "path",
        "audience"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "audience": {
          "enum": [
            "clinician",
            "patient",
            "both"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "printableRef": {
      "type": "object",
      "required": [
        "id",
        "title",
        "path",
        "format"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "format": {
          "enum": [
            "letter",
            "a4",
            "half_letter"
          ]
        }
      },
      "additionalProperties": false
    },
    "topic": {
      "type": "object",
      "required": [
        "id",
        "title",
        "audience",
        "blocks",
        "meta"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "audience": {
          "enum": [
            "clinician",
            "patient",
            "both"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/block"
          }
        },
        "meta": {
          "type": "object",
          "required": [
            "source",
            "last_reviewed"
          ],
          "properties": {
            "source": {
              "type": "string"
            },
            "last_reviewed": {
              "type": "string"
            },
            "notes": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "block": {
      "type": "object",
      "required": [
        "type",
        "id",
        "audience"
      ],
      "properties": {
        "type": {
          "enum": [
            "text",
            "checklist",
            "table",
            "warning",
            "calculator",
            "printable_ref",
            "section",
            "key_value",
            "list",
            "alert",
            "accordion",
            "link",
            "resource_link",
            "resource_list",
            "step_list",
            "info_card",
            "decision_tree",
            "navigation_grid"
          ]
        },
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "audience": {
          "enum": [
            "clinician",
            "patient",
            "both"
          ]
        },
        "content": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "headers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "level": {
          "enum": [
            "info",
            "caution",
            "danger"
          ]
        },
        "fn": {
          "type": "string"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "key",
              "label",
              "unit",
              "required"
            ],
            "properties": {
              "key": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "unit": {
                "type": "string"
              },
              "min": {
                "type": "number"
              },
              "max": {
                "type": "number"
              },
              "step": {
                "type": "number"
              },
              "required": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "key",
              "label",
              "unit"
            ],
            "properties": {
              "key": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "unit": {
                "type": "string"
              },
              "precision": {
                "type": "integer"
              }
            },
            "additionalProperties": false
          }
        },
        "printable_id": {
          "type": "string"
        },
        "share_variant": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "content": {
              "type": "string"
            },
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "text"
              }
            }
          },
          "then": {
            "required": [
              "content"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "checklist"
              }
            }
          },
          "then": {
            "required": [
              "items"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "table"
              }
            }
          },
          "then": {
            "required": [
              "headers",
              "rows"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "warning"
              }
            }
          },
          "then": {
            "required": [
              "content",
              "level"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "calculator"
              }
            }
          },
          "then": {
            "required": [
              "fn",
              "inputs",
              "outputs"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "printable_ref"
              }
            }
          },
          "then": {
            "required": [
              "printable_id"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "accordion"
              }
            }
          },
          "then": {
            "required": [
              "items"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "step_list"
              }
            }
          },
          "then": {
            "required": [
              "items"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "list"
              }
            }
          },
          "then": {
            "required": [
              "items"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "resource_list"
              }
            }
          },
          "then": {
            "required": [
              "items"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "key_value"
              }
            }
          },
          "then": {
            "required": [
              "data"
            ]
          }
        }
      ]
    }
  },
  "updated_at": "2026-01-06T21:23:00"
}